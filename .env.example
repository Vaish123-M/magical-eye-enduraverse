# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=False
APP_NAME="MagicalEye — Defect Detection API"

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite for dev, switch to PostgreSQL for production
DATABASE_URL=sqlite:///./magical_eye.db
# DATABASE_URL=postgresql://user:password@localhost:5432/magical_eye

# ── Security ─────────────────────────────────────────────────────────────────
# CHANGE THIS IN PRODUCTION! Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-secrets-module
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                    # local | s3
LOCAL_STORAGE_PATH=storage/images
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# ── AI Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=model/exports/defect_model.onnx
MODEL_INPUT_SIZE=224
CONFIDENCE_THRESHOLD=0.5

# ── Cloud Sync ───────────────────────────────────────────────────────────────
CLOUD_SYNC_ENABLED=False
CLOUD_SYNC_ENDPOINT=

# ── Alerts ───────────────────────────────────────────────────────────────────
ALERT_EMAIL_ENABLED=False
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_RECIPIENTS=
